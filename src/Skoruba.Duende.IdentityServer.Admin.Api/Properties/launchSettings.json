{
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "https://localhost:44302",
      "sslPort": 44302
    }
  },
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Skoruba.Duende.IdentityServer.Admin.Api": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "Kestrel__Certificates__Default__Subject": "dev.localhost",
        "Kestrel__Certificates__Default__Store": "My",
        "Kestrel__Certificates__Default__Location": "CurrentUser",
        "Kestrel__Certificates__Default__AllowInvalid": "true"
      },
      "applicationUrl": "https://api.dev.localhost:5100"
    }
  }
}
